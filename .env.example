# ===============================
# Syntec AI Chatbot Configuration
# ===============================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git!

# OpenAI API Configuration (REQUIRED)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# DeepInfra API Configuration (OPTIONAL - for PNG OCR)
# Get your API key from: https://deepinfra.com/
# If not provided, PNG files will be skipped during ingestion
DEEPINFRA_API_KEY=YOUR_DEEPINFRA_API_KEY_HERE

# Server Configuration
PORT=5001
FLASK_ENV=development

# CORS Configuration (comma-separated, no spaces)
# Development (local):
CORS_ORIGINS=http://localhost:3000,http://localhost:5176,http://localhost:80

# Production (uncomment and modify for production):
# CORS_ORIGINS=https://build.syntecgroup.com,https://syntecgroup.com,https://www.syntecgroup.com

# Redis Configuration
# Docker Compose (default):
REDIS_URL=redis://redis:6379/0
# Native/Local Redis:
# REDIS_URL=redis://localhost:6379/0

# Optional: Production Settings
# Uncomment these for production deployment:
# FLASK_ENV=production
# MAX_CONTENT_LENGTH=52428800  # 50MB file upload limit
